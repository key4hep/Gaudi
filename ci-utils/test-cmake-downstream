#/bin/bash -ex
export LCG_VERSION=$1
export platform=$2

export PROJECT=dummyGaudiDownstreamProject
export SOURCE_DIR=$PWD/cmake/tests/$PROJECT
export BUILD_DIR=$PWD/build-$PROJECT

if [ ! -e Gaudi-*.tar.zst ] ; then
    echo "this script must be run from gitlab-ci"
    exit 1
fi

if [ ! -d $PWD/lcg-toolchains ] ; then
    # Get LHCb toolchain helpers
    git clone https://gitlab.cern.ch/lhcb-core/lcg-toolchains.git
fi

filename=$(ls Gaudi-*.tar.zst)
tar xfv $filename
export CMAKE_PREFIX_PATH=$PWD/${filename%.tar.zst}:$CMAKE_PREFIX_PATH

cmake --version
cmake -S $SOURCE_DIR -B $BUILD_DIR -Wno-dev -DCMAKE_TOOLCHAIN_FILE=$PWD/lcg-toolchains/LCG_${LCG_VERSION}/${platform}.cmake -DGAUDI_TEST_PUBLIC_HEADERS_BUILD=yes
ccache -z
# build
cmake --build $BUILD_DIR
# test built executable
$BUILD_DIR/run mainexe
