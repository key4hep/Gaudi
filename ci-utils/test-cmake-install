#/bin/bash -ex
if [ ! -e install_dirs.sh -o ! -e Gaudi-*.tar.zst ] ; then
    echo "this script must be run from gitlab-ci"
    exit 1
fi

source install_dirs.sh
filename=$(ls Gaudi-*.tar.zst)
tar xfv $filename
cd ${filename%.tar.zst}
